# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_DB_CONNECTION=

# ── JWT / Auth ─────────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_LIFE=1h
REFRESH_TOKEN_LIFE=7d
COOKIE_SECRET=

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=local
LOG_LEVEL=info

# ── SendGrid ───────────────────────────────────────────────────────────────────
